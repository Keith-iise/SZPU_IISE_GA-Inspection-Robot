        "format": "<div style=\"text-align: center; font-family: Arial, sans-serif;\">\n\n  <!-- 时间戳 -->\n  <p style=\"font-size: 12px; color: #666;\">\n    相机回传: {{ $flow.lastupdate }}\n  </p>\n  <!-- 显示字符串 -->\n  <p style=\"font-size: 18px; color: #333; margin: 10px 0;\">\n    {{msg.payload.message}}\n  </p>\n  <!-- 图像显示 -->\n  <img ng-src=\"data:image/jpeg;base64,{{msg.payload.image}}\" \n       style=\"max-width: 100%; height: auto; border: 1px solid #ccc; border-radius: 8px;\"\n       alt=\"Camera Stream\">\n\n\n\n</div>\n\n<script>\n// 更新时间戳\n(function(scope) {\n    scope.$watch('msg', function(msg) {\n        if (msg && msg.payload) {\n            // 更新时间\n            scope.$flow.lastupdate = new Date().toLocaleTimeString();\n        }\n    });\n})(scope);\n</script>",
