        ]
    },
    {
        "id": "2c09932ea496e8c0",
        "type": "function",
        "z": "9e5efdeed23e5991",
        "name": "获取光照",
        "func": "if (msg.payload[0] == 0x02)\n{\n    var lux = msg.payload[5]*256+msg.payload[6]\n    \n    \n    var msgTemp = { payload: lux };\n    \n\n    return msgTemp;\n}\n\n    // return msg;\n\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 660,
        "y": 420,
