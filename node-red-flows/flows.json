        "name": "function 6",
        "func": "\nif (msg.payload != 0)\n{\n    var msgMsage = { payload: \"现场发现烟雾，请注意\" };\n    var msgColor = { payload: 'red'  };\n    return [msgMsage,msgColor];\n}\nelse\n{\n\n\n    var msgColor = { payload: 'green'  };\n    return [null,msgColor];\n}\n\n\n\n",
