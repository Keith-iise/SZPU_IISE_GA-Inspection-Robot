    {
        "id": "9ee8b1bc75fb6e08",
        "type": "function",
        "z": "9e5efdeed23e5991",
        "name": "获取湿度",
        "func": "if (msg.payload[0] == 0x01)\n{\n    var wen = msg.payload[3]*256+msg.payload[4]\n    var shi = msg.payload[5]*256+msg.payload[6]\n    \n    var msgTemp = { payload: wen / 10 };\n    var msgHumidity = { payload: shi /10 };\n\n    return [msgTemp, msgHumidity];\n}\n\n    // return msg;\n\n",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 660,
        "y": 300,
        "wires": [
