        "z": "9e5efdeed23e5991",
        "name": "获取烟雾",
        "func": "if (msg.payload[0] == 0x03) {\n    var yan = msg.payload[4]\n\n\n    var msgTemp = { payload: yan };\n\n\n    return msgTemp;\n}\n\n// return msg;\n\n",
